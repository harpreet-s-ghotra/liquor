{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://liquor-pos.local/schemas/ai-review.schema.json",
  "title": "AI Review Result",
  "type": "object",
  "additionalProperties": false,
  "required": ["summary", "findings", "tests"],
  "properties": {
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["severity", "file", "line", "issue", "action"],
        "properties": {
          "severity": {
            "type": "string",
            "enum": ["high", "medium", "low"]
          },
          "file": {
            "type": "string",
            "minLength": 1
          },
          "line": {
            "type": "integer",
            "minimum": 1
          },
          "issue": {
            "type": "string",
            "minLength": 1
          },
          "action": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "tests": {
      "type": "object",
      "additionalProperties": false,
      "required": ["required", "commands"],
      "properties": {
        "required": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "commands": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
